<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whatsapp</title>
    <link rel ="stylesheet" href = "./style.css">
</head>
<script>
function confirmDelete(id) {
    if (confirm("Are you sure you want to delete this chat?")) {
        // Redirect to delete route
        window.location.href = `/chats/${id}/delete`;
    }
}
</script>

<body>
    <h3>All Messages!!</h3>
    <form method = "GET" action ="/chats/new">
        <button>New Chat</button>
    </form>
    
    <br><br>
    <% for(let chat of chats){ %>
    <div class = "chat">
        <p>from: <%= chat.from %></p>
        <div class="msg">
            <i><p>msg: <%= chat.msg %></p></i>
            <form method ="GET" action = "/chats/<%= chat._id %>/edit">
                <button>Edit</button>
            </form>
            <br>
            <form method = "post" action = "/chats/<%= chat._id %>?_method=DELETE"  onsubmit="return confirm('Are you sure you want to delete this chat?')">
                <button onclick="confirmDelete('<%= chat._id %>')">Delete</button>

            </form>
        </div>
        
        <p>to: <%= chat.to %></p>
        <p> <%= chat.created_at.toString().split(" ").slice(0,4).join("-") %></p>
        <p>Created_at: <%= chat.created_at %></p>
        

    </div>
    <hr>
<%}%>
</body>

</html>

