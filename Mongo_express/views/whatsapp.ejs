<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whatsapp</title>
    <link rel ="stylesheet" href = "./style.css">
</head>
<!-- <style>
    .msg{
        background-color:rgb(165, 215, 46);
    }
</style> -->
<body>
    <h3>All Messages!!</h3>
    <form method = "GET" action ="/chats/new">
        <button>New Chat</button>
    </form>
    
    <br><br>
    <% for(let chat of chats){ %>
    <div class = "chat">
        <p>from: <%= chat.from %></p>
        <div class="msg">
            <i><p>msg: <%= chat.msg %></p></i>
        </div>
        
        <p>to: <%= chat.to %></p>
        <p>Created_at: <%= chat.created_at %></p>
        

    </div>
    <hr>
<%}%>
</body>

</html>

